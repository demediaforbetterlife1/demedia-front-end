{
  "name": "DeMedia - Social Media Platform",
  "short_name": "DeMedia",
  "description": "Connect, share, and explore with DeMedia - the next generation social media platform",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#00bcd4",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en",
  "categories": ["social", "entertainment", "lifestyle"],
  "icons": [
    {
      "src": "/assets/images/logo.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/assets/images/logo1.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Home Feed",
      "short_name": "Home",
      "description": "View your home feed",
      "url": "/home",
      "icons": [{ "src": "/assets/images/logo.png", "sizes": "96x96" }]
    },
    {
      "name": "Messages",
      "short_name": "Chat",
      "description": "View your messages",
      "url": "/messeging",
      "icons": [{ "src": "/assets/images/logo.png", "sizes": "96x96" }]
    },
    {
      "name": "Profile",
      "short_name": "Profile",
      "description": "View your profile",
      "url": "/profile",
      "icons": [{ "src": "/assets/images/logo.png", "sizes": "96x96" }]
    },
    {
      "name": "Create Post",
      "short_name": "Post",
      "description": "Create a new post",
      "url": "/posts/create",
      "icons": [{ "src": "/assets/images/logo.png", "sizes": "96x96" }]
    }
  ],
  "screenshots": [
    {
      "src": "/assets/images/logo1.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "wide",
      "label": "DeMedia Home Feed"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "share_target": {
    "action": "/posts/create",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "video/*"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+demedia",
      "url": "/?action=%s"
    }
  ],
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "file_handlers": [
    {
      "action": "/posts/create",
      "accept": {
        "image/*": [".jpg", ".jpeg", ".png", ".gif", ".webp"],
        "video/*": [".mp4", ".webm", ".mov"]
      }
    }
  ]
}
